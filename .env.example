# ===== Slack =====
# 봇 토큰 (xoxb-...) — OAuth & Permissions 에서 발급
SLACK_BOT_TOKEN=xoxb-your-bot-token
# 앱 레벨 토큰 (xapp-...) — Socket Mode 용, scope: connections:write
SLACK_APP_TOKEN=xapp-your-app-token

# 트리거 이모지 이름 (콜론 제외). 🎫 = ticket
TRIGGER_EMOJI=ticket
# 처리할 채널 ID 화이트리스트 (쉼표구분). 비우면 모든 채널 허용
ALLOWED_CHANNELS=

# ===== Jira (Atlassian Cloud) =====
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
# https://id.atlassian.com/manage-profile/security/api-tokens 에서 발급
JIRA_API_TOKEN=your-jira-api-token
# 이슈를 생성할 프로젝트 키
JIRA_PROJECT_KEY=PROJ
# 이슈타입 id (본인 Jira 프로젝트의 "작업/Task" 등 id)
JIRA_ISSUE_TYPE_ID=10001
# 담당자로 지정할 계정 이메일 (Jira 계정 못 찾을 때의 폴백)
JIRA_ASSIGNEE_EMAIL=you@example.com
# 항상 붙일 라벨 (쉼표구분)
JIRA_DEFAULT_LABELS=monitoring
# 지문 중복제거용 라벨 prefix
FINGERPRINT_LABEL_PREFIX=autoexc-

# 스택트레이스에서 내 앱 프레임을 식별할 패키지 prefix (예: com.mycompany)
APP_PACKAGE_PREFIX=com.example
# 제목 라벨: [{서비스} {TITLE_LABEL}] 형태
TITLE_LABEL=monitoring

# 본문 맨 아래 원인/수정/효과 빈 골격을 넣을지 (true/false)
APPEND_RESOLUTION_SKELETON=true
