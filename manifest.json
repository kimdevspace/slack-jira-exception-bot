{
  "display_information": {
    "name": "Exception to Jira Bot",
    "description": "모니터링 채널 예외 메시지에 티켓 이모지 반응 시 Jira에 자동 등록",
    "background_color": "#1d1c1d"
  },
  "features": {
    "bot_user": {
      "display_name": "monitoring-bot",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "reactions:read",
        "reactions:write",
        "channels:history",
        "groups:history",
        "chat:write",
        "users:read",
        "users:read.email"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "reaction_added"
      ]
    },
    "interactivity": {
      "is_enabled": false
    },
    "socket_mode_enabled": true,
    "org_deploy_enabled": false,
    "token_rotation_enabled": false
  }
}
